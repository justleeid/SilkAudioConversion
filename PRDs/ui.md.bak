3.3 字体使用规范
vue




<!-- ✅ 正确使用示例 -->
<template>
  <!-- 页面标题 -->
  <h1 class="text-h1">Silk 音频转换器</h1>
  
  <!-- 模块标题 -->
  <h2 class="text-h2">上传音频文件</h2>
  
  <!-- 正文内容 -->
  <p class="text-body-regular">拖拽文件到此处或点击上传</p>
  
  <!-- 辅助信息 -->
  <span class="text-body-caption">支持 .silk .wav .mp3 格式</span>
</template>

<style scoped>
.text-h1 { font: 600 32px/40px var(--font-family-base); }
.text-h2 { font: 600 24px/32px var(--font-family-base); }
.text-body-regular { font: 400 14px/22px var(--font-family-base); }
.text-body-caption { font: 400 12px/18px var(--font-family-base); }
</style>
