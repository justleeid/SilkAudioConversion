3. 字体排印
3.1 字体家族
scss




// 字体栈定义
:root {
  // 中文优先使用系统字体，保证加载速度
  --font-family-base: 
    -apple-system,
    BlinkMacSystemFont,
    'Segoe UI',
    'PingFang SC',
    'Hiragino Sans GB',
    'Microsoft YaHei',
    'Helvetica Neue',
    Helvetica,
    Arial,
    sans-serif;
  
  // 等宽字体用于代码/文件信息
  --font-family-mono:
    'SF Mono',
    'Fira Code',
    'Consolas',
    'Monaco',
    monospace;
}
