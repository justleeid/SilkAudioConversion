# 服务器配置
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 文件上传配置
UPLOAD_DIR=./uploads
TEMP_DIR=./temp
OUTPUT_DIR=./output
MAX_FILE_SIZE=52428800
MAX_FILE_COUNT=50

# SILK 工具路径
SILK_DECODER_BIN=./tools/silk-v3-decoder/silk/decoder
SILK_ENCODER_BIN=./tools/silk-v3-decoder/silk/encoder

# 任务队列配置
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=3600

# 暂存区配置
CACHE_EXPIRE_HOURS=48
CACHE_CLEANUP_INTERVAL=3600

# 数据库配置 — MySQL（音频导入）
DB_AUDIO_HOST=172.16.8.52
DB_AUDIO_PORT=3306
DB_AUDIO_USER=lan
DB_AUDIO_PASSWORD=
DB_AUDIO_NAME=xiaozhi
DB_AUDIO_CHARSET=utf8mb4
DB_AUDIO_TABLE=ai_agent_chat_audio
DB_HISTORY_TABLE=ai_agent_chat_history

# 数据库配置 — SQL Server（音频导入）
DB_MSSQL_HOST=172.16.8.52
DB_MSSQL_PORT=1433
DB_MSSQL_USER=lan
DB_MSSQL_PASSWORD= 
DB_MSSQL_NAME=xiaozhi
DB_MSSQL_SCHEMA=dbo
DB_MSSQL_TABLE=ai_agent_chat_audio
DB_MSSQL_HISTORY_TABLE=ai_agent_chat_history
# ODBC 驱动名称（按照目标主机安装的驱动设置，例如 'ODBC Driver 17 for SQL Server'）
DB_MSSQL_DRIVER=ODBC Driver 17 for SQL Server
